# SweatItOut — .gitignore

# ── SECRET credentials — NEVER COMMIT ────────────────────────────
config.js

# ── OS & editor junk ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
*.code-workspace

# ── Logs ─────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── Node (if using any tooling) ───────────────────────────────────
node_modules/
.env
.env.local
.env.*.local

# ── Build outputs ─────────────────────────────────────────────────
dist/
build/